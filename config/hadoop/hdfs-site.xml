<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <!-- ===== HA NAMESERVICE CONFIG ===== -->
  <property>
    <name>dfs.nameservices</name>
    <value>clusterA</value>
  </property>
  <property>
    <name>dfs.ha.namenodes.clusterA</name>
    <value>nn1,nn2</value>
  </property>

  <!-- RPC addresses — used by clients and DataNodes to talk to NameNodes -->
  <property>
    <name>dfs.namenode.rpc-address.clusterA.nn1</name>
    <value>node01:8020</value>
  </property>
  <property>
    <name>dfs.namenode.rpc-address.clusterA.nn2</name>
    <value>node02:8020</value>
  </property>

  <!-- HTTP addresses (Web UI) -->
  <property>
    <name>dfs.namenode.http-address.clusterA.nn1</name>
    <value>node01:9870</value>
  </property>
  <property>
    <name>dfs.namenode.http-address.clusterA.nn2</name>
    <value>node02:9870</value>
  </property>

  <!-- ===== JOURNALNODE CONFIG ===== -->
  <!-- Shared edit log — both NNs read/write here so standby is always up to date -->
  <property>
    <name>dfs.namenode.shared.edits.dir</name>
    <value>qjournal://node01:8485;node02:8485;node03:8485/clusterA</value>
  </property>
  <property>
    <name>dfs.journalnode.edits.dir</name>
    <value>/var/hadoop/journal</value>
  </property>

  <!-- ===== AUTOMATIC FAILOVER ===== -->
  <property>
    <name>dfs.ha.automatic-failover.enabled</name>
    <value>true</value>
  </property>
  <property>
    <name>dfs.client.failover.proxy.provider.clusterA</name>
    <value>org.apache.hadoop.hdfs.server.namenode.ha.ConfiguredFailoverProxyProvider</value>
  </property>
  <!-- Fencing: use shell(/bin/true) for dev environment — in prod use SSH or STONITH -->
  <property>
    <name>dfs.ha.fencing.methods</name>
    <value>shell(/bin/true)</value>
  </property>

  <!-- ===== STORAGE DIRECTORIES ===== -->
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>/var/hadoop/namenode</value>
  </property>
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>/var/hadoop/datanode</value>
  </property>
  <!-- Replication factor = 1 as required for this dev cluster -->
  <property>
    <name>dfs.replication</name>
    <value>1</value>
  </property>
</configuration>
